{
    "my rules": {
    },
    "$map": {
    },
    "$meta": {
        "fields": {
            "$platforms": "",
            "Other fields": "See fields under '$m / $modifications' in user_rules.json"
        },
        "example": {
            "an example rule group": [
                {
                    "$p": [ "macos", "ios" ],
                    "$-": "dns"
                },
                {
                    "route": [
                        {
                            "$p": [ "macos", "ios" ],
                            "$-": [ "auto_detect_interface", "override_android_vpn" ],
                            "$explanation": "If fetching client is macOS or iOS, remove 'auto_detect_interface' and 'override_android_vpn' in 'route'."
                        },
                        {
                            "default_domain_resolver": {
                                "$p": [ "macos", "ios" ],
                                "$-": [ "rewrite_ttl", "disable_cache" ],
                                "$explanations": "If fetching client is macOS or iOS, remove 'rewrite_ttl' and 'disable_cache' objects insides 'default_domain_resolver' under 'route'."
                            }
                        },
                        {
                            "$p": "linux",
                            "$c": { "final": null },
                            "$=": {
                                "auto_redirect": true,
                                "default_mark": 10086
                            },
                            "$explanations": "If fetching client is Linux, and 'final' is not set, set 'auto_redirect' to true and 'default_mark' to 10086 in 'route'. "
                        },
                        {
                            "$p": "android",
                            "$=": {
                                "rule_set": [
                                    {
                                        "tag": "geosite_example",
                                        "type": "remote",
                                        "url": "https://example.com/geosite_example.json"
                                    },
                                    {
                                        "tag": "geoip_example",
                                        "type": "remote",
                                        "url": "https://example.com/geoip_example.json"
                                    }
                                ],
                                "default_domain_resolver": {
                                    "disable_cache": "true"
                                }
                            },
                            "$explanations": "If fetching client is Android, set 'rule_set' as such, and enable 'disable_cache' for 'default_domain_resolver'."
                        }
                    ],
                    "inbounds": [
                        {
                            "$p": "linux",
                            "$c": [
                                { "type": "tun" },
                                {
                                    "tcp_fast_open": true,
                                    "disable_tcp_keep_alive": true
                                }
                            ],
                            "$-": "udp_timeout",
                            "$explanations": "If the client is linux and the inbound is of type tun or enabled both 'tcp_fast_open' and 'disable_tcp_keep_alive', remove 'udp_timeout'."
                        }
                    ]
                }
            ]
        }
    }
}
